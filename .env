# Environment variables for Smart Route Recommender
NODE_ENV=production
PORT=3000

# External API endpoints (can be customized for different regions)
NOMINATIM_API=https://nominatim.openstreetmap.org/search
OSRM_API=https://router.project-osrm.org/route/v1/driving

# Closure data path (adjust if roads.json is in different location)
ROADS_DATA_PATH=../traffic-parser-bot/data/roads.json

# Notification settings
POLL_INTERVAL_MINUTES=15
CLOSURE_WARNING_HOURS=4

# Map configuration
DEFAULT_LAT=9.03
DEFAULT_LNG=38.74
DEFAULT_ZOOM=13
